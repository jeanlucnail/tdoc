#!/usr/bin/env bash
#
# TDOC — Termux Doctor
#

set -o errexit
set -o nounset
set -o pipefail

export TDOC_ROOT="${PREFIX}/lib/tdoc"

[[ -d "$TDOC_ROOT/core" ]] || { echo "TDOC: core not found at $TDOC_ROOT" >&2; exit 127; }

if [[ "${1:-}" == "--lang" && -n "${2:-}" ]]; then
  export TDOC_LANG="$2"
  shift 2
fi

source "$TDOC_ROOT/core/init.sh"

cmd="${1:-help}"

print_help() {
  echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  echo -e "${CYAN}🛰 Termux Doctor — Help Menu${RESET}"
  echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"; echo
  echo -e "  ${BOLD}Diagnosis:${RESET}"
  echo -e "  ${GREEN}tdoc scan${RESET}                  $(t L_SCAN_HEADER)"
  echo -e "  ${GREEN}tdoc repo-scan [path]${RESET}      $(t L_REPO_SCAN_HEADER)"
  echo -e "  ${GREEN}tdoc repo-fix${RESET}              Fix issues found by repo-scan"
  echo -e "  ${GREEN}tdoc repo-fix --preview${RESET}    Preview repo fixes (dry-run)"
  echo -e "  ${GREEN}tdoc repo-fix --auto${RESET}       Auto-fix repo issues"
  echo -e "  ${GREEN}tdoc diagnose [error]${RESET}      $(t L_DIAG_HEADER)"
  echo -e "  ${GREEN}tdoc diagnose --last${RESET}       $(t L_DIAG_FROM_LAST_SCAN)"
  echo -e "  ${GREEN}tdoc status${RESET}                $(t L_STATUS_HEADER)"
  echo -e "  ${GREEN}tdoc explain${RESET}               $(t L_EXPLAIN_HEADER)"
  echo -e "  ${GREEN}tdoc check <pkg>${RESET}           $(t L_CHECK_HEADER)"
  echo
  echo -e "  ${BOLD}Fix:${RESET}"
  echo -e "  ${GREEN}tdoc fix${RESET}                   $(t L_FIX_HEADER)"
  echo -e "  ${GREEN}tdoc fix --preview${RESET}         $(t L_FIX_PREVIEW_HEADER)"
  echo -e "  ${GREEN}tdoc fix --auto${RESET}            $(t L_FIX_AUTO_HEADER)"
  echo
  echo -e "  ${BOLD}Report:${RESET}"
  echo -e "  ${GREEN}tdoc checkup${RESET}               Full Checkup Report"
  echo -e "  ${GREEN}tdoc checkup --save${RESET}        Save report to ~/.tdoc/checkup_*.txt"
  echo -e "  ${GREEN}tdoc checkup --json${RESET}        Output report as JSON"
  echo -e "  ${GREEN}tdoc history${RESET}               $(t L_HISTORY_HEADER)"
  echo -e "  ${GREEN}tdoc doctor --json${RESET}         Doctor JSON"
  echo -e "  ${GREEN}tdoc doctor --json-ai${RESET}      Doctor JSON + AI"
  echo
  echo -e "  ${BOLD}Security:${RESET}"
  echo -e "  ${GREEN}tdoc security${RESET}              $(t L_SEC_HEADER)"
  echo -e "  ${GREEN}tdoc security --json${RESET}       Security JSON"
  echo
  echo -e "  ${BOLD}Tools:${RESET}"
  echo -e "  ${GREEN}tdoc benchmark${RESET}             $(t L_BENCH_HEADER)"
  echo -e "  ${GREEN}tdoc watch [s]${RESET}             $(t L_WATCH_HEADER)"
  echo -e "  ${GREEN}tdoc doctor --live [s]${RESET}     $(t L_WATCH_HEADER)"
  echo -e "  ${GREEN}tdoc lang list${RESET}             $(t L_LANG_CURRENT)"
  echo -e "  ${GREEN}tdoc lang set <code>${RESET}       $(t L_LANG_SET)"
  echo -e "  ${GREEN}tdoc version${RESET}               $(t L_VER_HEADER)"
  echo
  echo -e "  ${BOLD}Language flags:${RESET}"
  echo -e "  ${GREEN}tdoc --lang id scan${RESET}        Override language for one command"
  echo
  echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
}

mkdir -p "${PREFIX}/var/lib/tdoc"

case "$cmd" in
  version|-v|--version) source "$TDOC_ROOT/core/ui_version.sh"; tdoc_version_ui ;;
  scan)      source "$TDOC_ROOT/core/scan.sh" ;;
  repo-scan) shift; source "$TDOC_ROOT/core/repo_scan.sh" "${1:-$PWD}" ;;
  repo-fix)  shift; source "$TDOC_ROOT/core/repo_fix.sh" "${1:-}" ;;
  diagnose)  shift; source "$TDOC_ROOT/core/diagnose.sh" "$@" ;;
  status)
    [[ -f "$TDOC_ROOT/core/status.sh" ]] || { echo "$(t L_STATUS_NO_STATE)"; exit 1; }
    source "$TDOC_ROOT/core/status.sh" ;;
  fix)
    source "$TDOC_ROOT/core/scan.sh" > /dev/null 2>&1 || true
    case "${2:-}" in
      --preview) source "$TDOC_ROOT/core/fix_preview.sh" ;;
      --auto)    source "$TDOC_ROOT/core/fix_auto.sh" ;;
      *)         source "$TDOC_ROOT/core/fix.sh" ;;
    esac ;;
  doctor)
    case "${2:-}" in
      --json)    source "$TDOC_ROOT/core/scan.sh" >/dev/null 2>&1 || true; source "$TDOC_ROOT/core/doctor_json.sh" ;;
      --json-ai) source "$TDOC_ROOT/core/scan.sh" >/dev/null 2>&1 || true; source "$TDOC_ROOT/core/doctor_json_ai.sh" ;;
      --live)    INTERVAL="${3:-60}"; source "$TDOC_ROOT/core/watch.sh" "$INTERVAL" ;;
      *) echo "Usage:"; echo "  tdoc doctor --json | --json-ai | --live [seconds]" ;;
    esac ;;
  watch)     INTERVAL="${2:-60}"; source "$TDOC_ROOT/core/watch.sh" "$INTERVAL" ;;
  checkup)   shift; source "$TDOC_ROOT/core/checkup.sh" "${1:-}" ;;
  explain)   source "$TDOC_ROOT/core/explain.sh" ;;
  report)    cat "${PREFIX}/var/lib/tdoc/state.env" 2>/dev/null || echo "$(t L_STATUS_NO_STATE)" ;;
  history)   source "$TDOC_ROOT/core/history.sh" ;;
  check)     PKG="${2:-}"; source "$TDOC_ROOT/core/check.sh" "$PKG" ;;
  benchmark) source "$TDOC_ROOT/core/benchmark.sh" ;;
  security)
    case "${2:-}" in
      --json) source "$TDOC_ROOT/core/repo_security_json.sh" ;;
      *)      source "$TDOC_ROOT/core/repo_security_ui.sh" ;;
    esac ;;
  lang)      shift; source "$TDOC_ROOT/core/lang_cmd.sh" "$@" ;;
  update)
    echo "$(t L_UPDATE_MSG)"; echo
    echo "  $(t L_UPDATE_FROM_GITHUB):"; echo "    git -C \$PREFIX/lib/tdoc pull"; echo
    echo "  $(t L_UPDATE_OR):"; echo "    pkg update && pkg upgrade" ;;
  help|-h|--help|"") print_help ;;
  *) echo "$(t L_FIX_NO_HANDLER): tdoc $cmd" >&2; echo "Run: tdoc help" >&2; exit 1 ;;
esac
